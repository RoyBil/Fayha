# Copy this file to key.properties and fill in your keystore details.
# key.properties is gitignored — never commit it.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore ~/fayha-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias fayha
#
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=fayha
storeFile=/absolute/path/to/fayha-release.jks
